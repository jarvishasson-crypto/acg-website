<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>A Construction Group Inc. — Luxury Residential Construction · Beverly Hills</title>
  <meta name="description" content="A Construction Group Inc. builds extraordinary luxury residences in Beverly Hills, Bel Air, and greater Los Angeles. Family-owned, precision-driven." />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet" />

  <style>
    /* ─── RESET & BASE ─────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; font-size: 16px; }

    :root {
      --bg:      #080808;
      --bg-2:    #0E0E0E;
      --bg-3:    #161616;
      --bg-4:    #1C1C1C;
      --text:    #EDE8E0;
      --text-2:  #9A9087;
      --text-3:  #555050;
      --gold:    #C4A87E;
      --gold-lt: #D9BE9A;
      --border:  rgba(255,255,255,0.07);
      --serif:   'Cormorant Garamond', Georgia, serif;
      --sans:    'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
      --ease:    cubic-bezier(0.25, 0.46, 0.45, 0.94);
      --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
    }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      font-weight: 300;
      line-height: 1.6;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }

    img { display: block; max-width: 100%; }
    a { color: inherit; text-decoration: none; }
    button { cursor: pointer; border: none; background: none; font-family: inherit; color: inherit; }

    .container {
      width: 100%;
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 48px;
    }

    .label {
      display: block;
      font-family: var(--sans);
      font-size: 10px;
      font-weight: 400;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 24px;
    }

    /* Scroll reveal */
    .reveal {
      opacity: 0;
      transform: translateY(32px);
      transition: opacity 0.9s var(--ease-out), transform 0.9s var(--ease-out);
    }
    .reveal.visible {
      opacity: 1;
      transform: none;
    }
    .reveal-delay-1 { transition-delay: 0.1s; }
    .reveal-delay-2 { transition-delay: 0.2s; }
    .reveal-delay-3 { transition-delay: 0.3s; }
    .reveal-delay-4 { transition-delay: 0.4s; }

    /* ─── NAVIGATION ────────────────────────────────────────────── */
    .nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      padding: 28px 48px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      transition: padding 0.4s var(--ease), background 0.4s var(--ease), border-color 0.4s var(--ease);
      border-bottom: 1px solid transparent;
    }
    .nav.scrolled {
      padding: 16px 48px;
      background: rgba(8,8,8,0.96);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom-color: var(--border);
    }

    .nav-logo {
      display: flex;
      align-items: center;
      height: 44px;
      flex-shrink: 0;
    }
    .nav-logo svg { height: 44px; width: auto; }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 48px;
    }
    .nav-links a {
      font-family: var(--sans);
      font-size: 11px;
      font-weight: 400;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--text-2);
      transition: color 0.2s;
      position: relative;
    }
    .nav-links a::after {
      content: '';
      position: absolute;
      bottom: -3px; left: 0;
      width: 0; height: 1px;
      background: var(--gold);
      transition: width 0.3s var(--ease);
    }
    .nav-links a:hover { color: var(--text); }
    .nav-links a:hover::after { width: 100%; }

    .nav-cta {
      font-family: var(--sans);
      font-size: 11px;
      font-weight: 400;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--text) !important;
      padding: 10px 24px;
      border: 1px solid rgba(255,255,255,0.2);
      transition: border-color 0.2s, background 0.2s !important;
    }
    .nav-cta:hover {
      background: rgba(255,255,255,0.05) !important;
      border-color: rgba(255,255,255,0.4) !important;
    }
    .nav-cta::after { display: none !important; }

    .nav-hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      padding: 4px;
    }
    .nav-hamburger span {
      display: block;
      width: 24px;
      height: 1px;
      background: var(--text);
      transition: transform 0.3s, opacity 0.3s;
    }

    /* Mobile Menu */
    .mobile-menu {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 99;
      background: var(--bg);
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 40px;
      opacity: 0;
      transition: opacity 0.3s;
    }
    .mobile-menu.open { opacity: 1; }
    .mobile-menu a {
      font-family: var(--serif);
      font-size: 42px;
      font-weight: 300;
      color: var(--text);
      letter-spacing: 2px;
      transition: color 0.2s;
    }
    .mobile-menu a:hover { color: var(--gold); }

    /* ─── HERO ──────────────────────────────────────────────────── */
    .hero {
      position: relative;
      height: 100vh;
      min-height: 700px;
      display: flex;
      align-items: flex-end;
      overflow: hidden;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      background-image: url('https://images.unsplash.com/photo-1613977257363-707ba9348227?auto=format&fit=crop&w=2000&q=80');
      background-size: cover;
      background-position: center;
      transform: scale(1.06);
      transition: transform 8s var(--ease);
    }
    .hero-bg.loaded { transform: scale(1); }

    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to top,
        rgba(8,8,8,0.97) 0%,
        rgba(8,8,8,0.6) 40%,
        rgba(8,8,8,0.35) 100%
      );
    }

    .hero-content {
      position: relative;
      z-index: 2;
      padding: 0 48px 96px;
      max-width: 860px;
    }

    .hero-eyebrow {
      font-family: var(--sans);
      font-size: 10px;
      font-weight: 400;
      letter-spacing: 5px;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 28px;
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 1s 0.3s, transform 1s 0.3s var(--ease-out);
    }
    .hero-eyebrow.visible { opacity: 1; transform: none; }

    .hero h1 {
      font-family: var(--serif);
      font-size: clamp(56px, 7.5vw, 112px);
      font-weight: 300;
      line-height: 1.02;
      letter-spacing: -1px;
      color: var(--text);
      margin-bottom: 32px;
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 1.1s 0.5s, transform 1.1s 0.5s var(--ease-out);
    }
    .hero h1 em {
      font-style: italic;
      color: var(--gold);
    }
    .hero h1.visible { opacity: 1; transform: none; }

    .hero-desc {
      font-family: var(--sans);
      font-size: 14px;
      font-weight: 300;
      letter-spacing: 1px;
      color: var(--text-2);
      max-width: 480px;
      line-height: 1.8;
      margin-bottom: 48px;
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 1s 0.8s, transform 1s 0.8s var(--ease-out);
    }
    .hero-desc.visible { opacity: 1; transform: none; }

    .hero-actions {
      display: flex;
      align-items: center;
      gap: 40px;
      opacity: 0;
      transform: translateY(16px);
      transition: opacity 1s 1s, transform 1s 1s var(--ease-out);
    }
    .hero-actions.visible { opacity: 1; transform: none; }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 14px;
      font-family: var(--sans);
      font-size: 11px;
      font-weight: 400;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--bg);
      background: var(--text);
      padding: 16px 36px;
      transition: background 0.25s, color 0.25s;
    }
    .btn-primary:hover {
      background: var(--gold);
    }
    .btn-primary svg { width: 14px; height: 14px; flex-shrink: 0; transition: transform 0.3s; }
    .btn-primary:hover svg { transform: translateX(4px); }

    .btn-ghost {
      display: inline-flex;
      align-items: center;
      gap: 14px;
      font-family: var(--sans);
      font-size: 11px;
      font-weight: 400;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--text-2);
      border-bottom: 1px solid var(--border);
      padding-bottom: 3px;
      transition: color 0.2s, border-color 0.2s;
    }
    .btn-ghost:hover { color: var(--text); border-color: var(--text-3); }

    .hero-scroll {
      position: absolute;
      bottom: 40px; right: 48px;
      z-index: 2;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
      font-size: 9px;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: var(--text-3);
      writing-mode: vertical-rl;
      opacity: 0;
      animation: fadeInScroll 1s 1.5s var(--ease-out) forwards;
    }
    .hero-scroll::before {
      content: '';
      width: 1px;
      height: 56px;
      background: linear-gradient(to bottom, var(--gold), transparent);
    }
    @keyframes fadeInScroll { to { opacity: 1; } }

    /* ──── MARQUEE BAND ──────────────────────────────────────────────────────────────────────── */
    .marquee-band {
      overflow: hidden;
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      padding: 18px 0;
      background: var(--bg-2);
    }
    .marquee-track {
      display: flex;
      gap: 0;
      width: max-content;
      animation: marquee 28s linear infinite;
    }
    @keyframes marquee {
      from { transform: translateX(0); }
      to { transform: translateX(-50%); }
    }
    .marquee-item {
      display: flex;
      align-items: center;
      gap: 32px;
      padding: 0 48px;
      font-family: var(--sans);
      font-size: 10px;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: var(--text-3);
      white-space: nowrap;
    }
    .marquee-dot {
      width: 4px; height: 4px;
      border-radius: 50%;
      background: var(--gold);
      flex-shrink: 0;
    }

    /* ──── STATEMENT ──────────────────────────────────────────────────────────────────────────────────────────── */
    .statement {
      padding: 140px 0;
      background: var(--bg);
    }
    .statement .container {
      max-width: 960px;
    }
    .statement-text {
      font-family: var(--serif);
      font-size: clamp(28px, 3.5vw, 48px);
      font-weight: 300;
      line-height: 1.45;
      color: var(--text);
      letter-spacing: 0.2px;
    }
    .statement-text em {
      font-style: italic;
      color: var(--gold);
    }
    .statement-divider {
      width: 56px;
      height: 1px;
      background: var(--gold);
      margin: 56px 0;
    }
    .statement-meta {
      display: flex;
      gap: 64px;
    }
    .statement-stat .number {
      font-family: var(--serif);
      font-size: 52px;
      font-weight: 300;
      color: var(--text);
      line-height: 1;
      margin-bottom: 8px;
    }
    .statement-stat .number span {
      font-size: 28px;
      color: var(--gold);
    }
    .statement-stat .caption {
      font-size: 11px;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: var(--text-2);
    }

    /* ──── PORTFOLIO ──────────────────────────────────────────────────────────────────────────────────────────── */
    .portfolio {
      padding: 0 0 160px;
      background: var(--bg);
    }
    .section-header {
      padding: 0 48px;
      margin-bottom: 64px;
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
    }
    .section-header-left .label { margin-bottom: 16px; }
    .section-header h2 {
      font-family: var(--serif);
      font-size: clamp(36px, 4.5vw, 64px);
      font-weight: 300;
      line-height: 1.1;
      letter-spacing: -0.5px;
    }
    .section-header-right {
      font-size: 12px;
      color: var(--text-2);
      letter-spacing: 1px;
      padding-bottom: 8px;
    }
    .section-header-right a {
      border-bottom: 1px solid var(--text-3);
      padding-bottom: 2px;
      transition: color 0.2s, border-color 0.2s;
    }
    .section-header-right a:hover { color: var(--text); border-color: var(--text-2); }

    .portfolio-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: auto;
      gap: 2px;
    }

    .portfolio-item {
      position: relative;
      overflow: hidden;
      cursor: pointer;
    }
    .portfolio-item:nth-child(1) { grid-column: span 2; aspect-ratio: 16/10; }
    .portfolio-item:nth-child(2) { aspect-ratio: 4/5; }
    .portfolio-item:nth-child(3) { aspect-ratio: 4/5; }
    .portfolio-item:nth-child(4) { aspect-ratio: 16/10; }
    .portfolio-item:nth-child(5) { grid-column: span 2; aspect-ratio: 16/10; }

    .portfolio-img {
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform 0.8s var(--ease);
      background: var(--bg-3);
    }
    .portfolio-item:hover .portfolio-img { transform: scale(1.04); }

    .portfolio-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(8,8,8,0.9) 0%, rgba(8,8,8,0.2) 50%, transparent 100%);
      opacity: 0;
      transition: opacity 0.4s;
      display: flex;
      align-items: flex-end;
      padding: 32px;
    }
    .portfolio-item:hover .portfolio-overlay { opacity: 1; }

    .portfolio-info { }
    .portfolio-name {
      font-family: var(--serif);
      font-size: 22px;
      font-weight: 300;
      color: var(--text);
      display: block;
      margin-bottom: 6px;
    }
    .portfolio-detail {
      font-size: 11px;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: var(--gold);
    }

    /* ──── STORY ──────────────────────────────────────────────────────────────────────────────────────────────────────────────────── */
    .story {
      padding: 160px 0;
      background: var(--bg-2);
    }
    .story-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 96px;
      align-items: center;
    }
    .story-image-wrap {
      position: relative;
    }
    .story-image-wrap::before {
      content: '';
      position: absolute;
      inset: -24px -24px 24px 24px;
      border: 1px solid var(--border);
      z-index: 0;
    }
    .story-img {
      position: relative;
      z-index: 1;
      width: 100%;
      aspect-ratio: 4/5;
      object-fit: cover;
      background: var(--bg-3);
    }
    .story-badge {
      position: absolute;
      z-index: 2;
      bottom: -28px;
      right: -28px;
      width: 120px;
      height: 120px;
      background: var(--bg);
      border: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 4px;
    }
    .story-badge .badge-num {
      font-family: var(--serif);
      font-size: 36px;
      font-weight: 300;
      color: var(--gold);
      line-height: 1;
    }
    .story-badge .badge-text {
      font-size: 8px;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: var(--text-2);
      text-align: center;
      line-height: 1.5;
    }

    .story-content h2 {
      font-family: var(--serif);
      font-size: clamp(36px, 4vw, 56px);
      font-weight: 300;
      line-height: 1.15;
      letter-spacing: -0.3px;
      margin-bottom: 32px;
    }
    .story-content h2 em { font-style: italic; color: var(--gold); }
    .story-content p {
      font-size: 15px;
      line-height: 1.85;
      color: var(--text-2);
      margin-bottom: 20px;
    }
    .story-content p strong {
      font-weight: 400;
      color: var(--text);
    }
    .story-divider {
      width: 40px;
      height: 1px;
      background: var(--gold);
      margin: 40px 0;
    }
    .story-values {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
      margin-top: 48px;
    }
    .story-value {
      padding: 24px;
      border: 1px solid var(--border);
      background: rgba(255,255,255,0.02);
    }
    .story-value-title {
      font-family: var(--serif);
      font-size: 18px;
      font-weight: 300;
      color: var(--text);
      margin-bottom: 8px;
    }
    .story-value-text {
      font-size: 13px;
      color: var(--text-3);
      line-height: 1.7;
    }

    /* ──── SERVICES ──────────────────────────────────────────────────────────────────────────────────────────── */
    .services {
      padding: 160px 0;
      background: var(--bg);
    }
    .services-intro {
      text-align: center;
      max-width: 640px;
      margin: 0 auto 96px;
    }
    .services-intro h2 {
      font-family: var(--serif);
      font-size: clamp(32px, 4vw, 52px);
      font-weight: 300;
      letter-spacing: -0.3px;
      line-height: 1.15;
      margin-bottom: 24px;
    }
    .services-intro p {
      font-size: 15px;
      color: var(--text-2);
      line-height: 1.8;
    }
    .services-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
    }
    .service-item {
      background: var(--bg);
      padding: 56px 48px 64px;
      display: flex;
      flex-direction: column;
      gap: 24px;
      transition: background 0.3s;
      cursor: default;
    }
    .service-item:hover { background: var(--bg-3); }
    .service-num {
      font-family: var(--serif);
      font-size: 13px;
      font-weight: 300;
      color: var(--gold);
      letter-spacing: 2px;
    }
    .service-title {
      font-family: var(--serif);
      font-size: 28px;
      font-weight: 300;
      line-height: 1.2;
      color: var(--text);
    }
    .service-divider {
      width: 32px;
      height: 1px;
      background: var(--border);
      transition: background 0.3s;
    }
    .service-item:hover .service-divider { background: var(--gold); }
    .service-desc {
      font-size: 13px;
      line-height: 1.85;
      color: var(--text-2);
    }

    /* ──── PARTNERS ──────────────────────────────────────────────────────────────────────────────────────────── */
    .partners {
      padding: 160px 0;
      background: var(--bg-2);
      overflow: hidden;
    }
    .partners-header {
      text-align: center;
      margin-bottom: 96px;
    }
    .partners-header h2 {
      font-family: var(--serif);
      font-size: clamp(32px, 4vw, 52px);
      font-weight: 300;
      letter-spacing: -0.3px;
      line-height: 1.15;
      margin-bottom: 20px;
    }
    .partners-header p {
      font-size: 15px;
      color: var(--text-2);
      max-width: 520px;
      margin: 0 auto;
      line-height: 1.8;
    }
    .partners-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2px;
    }
    .partner-card {
      position: relative;
      overflow: hidden;
      aspect-ratio: 16/9;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 48px;
    }
    .partner-bg {
      position: absolute;
      inset: 0;
      object-fit: cover;
      width: 100%;
      height: 100%;
      background: var(--bg-3);
      transition: transform 0.7s var(--ease);
    }
    .partner-card:hover .partner-bg { transform: scale(1.04); }
    .partner-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(8,8,8,0.85) 0%, rgba(8,8,8,0.5) 100%);
    }
    .partner-content {
      position: relative;
      z-index: 1;
    }
    .partner-category {
      font-size: 9px;
      letter-spacing: 4px;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 14px;
    }
    .partner-name {
      font-family: var(--serif);
      font-size: clamp(24px, 3vw, 40px);
      font-weight: 300;
      color: var(--text);
      line-height: 1.1;
      margin-bottom: 16px;
    }
    .partner-desc {
      font-size: 13px;
      color: var(--text-2);
      line-height: 1.75;
      max-width: 380px;
    }
    .partner-link {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      margin-top: 28px;
      font-size: 10px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--text-2);
      border-bottom: 1px solid rgba(255,255,255,0.15);
      padding-bottom: 3px;
      transition: color 0.2s, border-color 0.2s;
    }
    .partner-link:hover { color: var(--gold); border-color: var(--gold); }

    /* ──── CONTACT ──────────────────────────────────────────────────────────────────────────────────────────────────────────────── */
    .contact {
      padding: 160px 0;
      background: var(--bg);
    }
    .contact-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 96px;
      align-items: start;
    }
    .contact-left h2 {
      font-family: var(--serif);
      font-size: clamp(36px, 4.5vw, 64px);
      font-weight: 300;
      line-height: 1.1;
      letter-spacing: -0.5px;
      margin-bottom: 32px;
    }
    .contact-left h2 em { font-style: italic; color: var(--gold); }
    .contact-left p {
      font-size: 14px;
      line-height: 1.85;
      color: var(--text-2);
      margin-bottom: 56px;
    }
    .contact-details {
      display: flex;
      flex-direction: column;
      gap: 24px;
    }
    .contact-item-label {
      font-size: 9px;
      letter-spacing: 3.5px;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 6px;
    }
    .contact-item-value {
      font-family: var(--serif);
      font-size: 18px;
      font-weight: 300;
      color: var(--text);
      letter-spacing: 0.3px;
    }
    .contact-item-value a {
      border-bottom: 1px solid rgba(255,255,255,0.1);
      transition: border-color 0.2s, color 0.2s;
    }
    .contact-item-value a:hover { color: var(--gold); border-color: var(--gold); }

    .contact-form {
      display: flex;
      flex-direction: column;
      gap: 24px;
    }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

    .field {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .field label {
      font-size: 9px;
      font-weight: 400;
      letter-spacing: 3.5px;
      text-transform: uppercase;
      color: var(--text-3);
    }
    .field input,
    .field textarea,
    .field select {
      background: transparent;
      border: none;
      border-bottom: 1px solid rgba(255,255,255,0.12);
      padding: 12px 0;
      font-family: var(--sans);
      font-size: 14px;
      font-weight: 300;
      color: var(--text);
      outline: none;
      transition: border-color 0.2s;
      width: 100%;
      -webkit-appearance: none;
    }
    .field input::placeholder,
    .field textarea::placeholder { color: var(--text-3); font-size: 13px; }
    .field input:focus,
    .field textarea:focus,
    .field select:focus { border-bottom-color: var(--gold); }
    .field textarea { resize: none; height: 96px; }
    .field select {
      background: var(--bg);
      padding-right: 20px;
      color: var(--text-3);
      cursor: pointer;
    }
    .field select option { background: var(--bg-4); color: var(--text); }

    .form-submit {
      display: inline-flex;
      align-items: center;
      gap: 16px;
      font-family: var(--sans);
      font-size: 11px;
      font-weight: 400;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--bg);
      background: var(--text);
      padding: 18px 48px;
      border: none;
      cursor: pointer;
      transition: background 0.25s;
      align-self: flex-start;
      margin-top: 8px;
    }
    .form-submit:hover { background: var(--gold); }
    .form-submit svg { width: 14px; height: 14px; transition: transform 0.3s; }
    .form-submit:hover svg { transform: translateX(4px); }

    /* ──── FOOTER ──────────────────────────────────────────────────────────────────────────────────────────────────────────────── */
    .footer {
      background: var(--bg-2);
      border-top: 1px solid var(--border);
      padding: 80px 0 48px;
    }
    .footer-top {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 64px;
      margin-bottom: 64px;
    }
    .footer-logo svg { height: 48px; width: auto; margin-bottom: 20px; }
    .footer-tagline {
      font-size: 13px;
      color: var(--text-3);
      line-height: 1.7;
      max-width: 260px;
    }
    .footer-col-title {
      font-size: 9px;
      letter-spacing: 3.5px;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 24px;
    }
    .footer-links {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .footer-links a {
      font-size: 13px;
      color: var(--text-3);
      transition: color 0.2s;
    }
    .footer-links a:hover { color: var(--text); }
    .footer-address {
      font-size: 13px;
      color: var(--text-3);
      line-height: 1.8;
      font-style: normal;
    }
    .footer-bottom {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-top: 40px;
      border-top: 1px solid var(--border);
    }
    .footer-copy {
      font-size: 11px;
      color: var(--text-3);
      letter-spacing: 1px;
    }
    .footer-socials {
      display: flex;
      gap: 28px;
    }
    .footer-socials a {
      font-size: 11px;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--text-3);
      transition: color 0.2s;
    }
    .footer-socials a:hover { color: var(--text); }

    /* ──── RESPONSIVE ──────────────────────────────────────────────────────────────────────────────────────────────────────────────── */
    @media (max-width: 1024px) {
      .container { padding: 0 32px; }
      .portfolio-grid { grid-template-columns: 1fr 1fr; }
      .portfolio-item:nth-child(1) { grid-column: span 2; }
      .portfolio-item:nth-child(5) { grid-column: span 2; }
      .story-grid { grid-template-columns: 1fr; gap: 64px; }
      .story-image-wrap::before { display: none; }
      .story-badge { bottom: 16px; right: 16px; }
      .contact-grid { grid-template-columns: 1fr; gap: 64px; }
      .footer-top { grid-template-columns: 1fr 1fr; }
    }

    @media (max-width: 768px) {
      .container { padding: 0 24px; }
      .nav { padding: 20px 24px; }
      .nav.scrolled { padding: 14px 24px; }
      .nav-links { display: none; }
      .nav-hamburger { display: flex; }
      .hero-content { padding: 0 24px 80px; }
      .hero-scroll { right: 24px; }
      .section-header { flex-direction: column; align-items: flex-start; gap: 20px; padding: 0 24px; }
      .portfolio-grid { grid-template-columns: 1fr; }
      .portfolio-item:nth-child(1),
      .portfolio-item:nth-child(5) { grid-column: span 1; }
      .portfolio-item { aspect-ratio: 4/3 !important; }
      .services-grid { grid-template-columns: 1fr; }
      .partners-grid { grid-template-columns: 1fr; }
      .footer-top { grid-template-columns: 1fr; gap: 40px; }
      .footer-bottom { flex-direction: column; gap: 20px; text-align: center; }
      .statement-meta { flex-direction: column; gap: 40px; }
      .story-values { grid-template-columns: 1fr; }
      .form-row { grid-template-columns: 1fr; }
    }
  </style>
</head>

<body>

  <!-- ──── NAVIGATION ──────────────────────────────────────────────────────────────────────────────────────────────────────────────── -->
  <nav class="nav" id="nav">
    <a href="#hero" class="nav-logo" aria-label="A Construction Group Inc.">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 220 72" fill="none">
        <polygon points="0,64 22,8 30,8 10,64" fill="#EDE8E0"/>
        <polygon points="44,64 22,8 30,8 52,64" fill="#EDE8E0"/>
        <rect x="12" y="36" width="30" height="3.5" fill="#EDE8E0"/>
        <polygon points="22,8 26,0 30,8" fill="#C4A87E"/>
        <text x="70" y="30" font-family="'Cormorant Garamond', Georgia, serif" font-size="17" font-weight="300" letter-spacing="5" fill="#EDE8E0">CONSTRUCTION</text>
        <text x="70" y="52" font-family="'Cormorant Garamond', Georgia, serif" font-size="17" font-weight="300" letter-spacing="5" fill="#EDE8E0">GROUP INC.</text>
        <rect x="70" y="35" width="148" height="0.75" fill="#C4A87E" opacity="0.6"/>
      </svg>
    </a>
    <div class="nav-links" role="navigation" aria-label="Main Navigation">
      <a href="#work">Work</a>
      <a href="#story">Story</a>
      <a href="#services">Services</a>
      <a href="#partners">Partners</a>
      <a href="#contact" class="nav-cta">Begin Your Project</a>
    </div>
    <button class="nav-hamburger" id="hamburger" aria-label="Open menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobileMenu" role="dialog" aria-modal="true">
    <a href="#work" class="mobile-link">Work</a>
    <a href="#story" class="mobile-link">Story</a>
    <a href="#services" class="mobile-link">Services</a>
    <a href="#partners" class="mobile-link">Partners</a>
    <a href="#contact" class="mobile-link">Contact</a>
  </div>


  <!-- ──── HERO ──────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────── -->
  <section class="hero" id="hero">
    <div class="hero-bg" id="heroBg"></div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <div class="hero-eyebrow" id="heroEyebrow">Beverly Hills · Est. 1998</div>
      <h1 id="heroH1">Building the<br><em>Extraordinary</em></h1>
      <p class="hero-desc" id="heroDesc">
        Luxury residential construction and full renovation across Beverly Hills,
        Bel Air, Holmby Hills, and greater Los Angeles. Where architectural
        vision meets uncompromising craft.
      </p>
      <div class="hero-actions" id="heroActions">
        <a href="#work" class="btn-primary">
          View Our Work
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M2 8h12M9 3l5 5-5 5"/>
          </svg>
        </a>
        <a href="#contact" class="btn-ghost">Start a Conversation</a>
      </div>
    </div>
    <div class="hero-scroll">Scroll</div>
  </section>


  <!-- ──── MARQUEE ──────────────────────────────────────────────────────────────────────────────────────────────────────────────── -->
  <div class="marquee-band" aria-hidden="true">
    <div class="marquee-track">
      <!-- Repeated twice for seamless loop -->
      <div class="marquee-item"><span class="marquee-dot"></span>Ground-Up Construction</div>
      <div class="marquee-item"><span class="marquee-dot"></span>Full Renovation</div>
      <div class="marquee-item"><span class="marquee-dot"></span>Design-Build</div>
      <div class="marquee-item"><span class="marquee-dot"></span>Beverly Hills</div>
      <div class="marquee-item"><span class="marquee-dot"></span>Bel Air</div>
      <div class="marquee-item"><span class="marquee-dot"></span>Holmby Hills</div>
      <div class="marquee-item"><span class="marquee-dot"></span>Brentwood</div>
      <div class="marquee-item"><span class="marquee-dot"></span>Pacific Palisades</div>
      <div class="marquee-item"><span class="marquee-dot"></span>$20M+ Projects</div>
      <div class="marquee-item"><span class="marquee-dot"></span>Ground-Up Construction</div>
      <div class="marquee-item"><span class="marquee-dot"></span>Full Renovation</div>
      <div class="marquee-item"><span class="marquee-dot"></span>Design-Build</div>
      <div class="marquee-item"><span class="marquee-dot"></span>Beverly Hills</div>
      <div class="marquee-item"><span class="marquee-dot"></span>Bel Air</div>
      <div class="marquee-item"><span class="marquee-dot"></span>Holmby Hills</div>
      <div class="marquee-item"><span class="marquee-dot"></span>Brentwood</div>
      <div class="marquee-item"><span class="marquee-dot"></span>Pacific Palisades</div>
      <div class="marquee-item"><span class="marquee-dot"></span>$20M+ Projects</div>
    </div>
  </div>


  <!-- ──── STATEMENT ────────────────────────────────────────────────────────────────────────────────────── -->
  <section class="statement">
    <div class="container">
      <p class="statement-text reveal">
        We don't build houses — we build <em>legacies</em>. Every project begins
        with a single conviction: that the spaces where life unfolds deserve
        nothing less than perfection in every detail, every material, every decision.
      </p>
      <div class="statement-divider reveal reveal-delay-1"></div>
      <div class="statement-meta">
        <div class="statement-stat reveal reveal-delay-1">
          <div class="number">25<span>+</span></div>
          <div class="caption">Years of Craft</div>
        </div>
        <div class="statement-stat reveal reveal-delay-2">
          <div class="number">$20M<span>+</span></div>
          <div class="caption">Average Project Value</div>
        </div>
        <div class="statement-stat reveal reveal-delay-3">
          <div class="number">100<span>%</span></div>
          <div class="caption">Referral-Driven</div>
        </div>
        <div class="statement-stat reveal reveal-delay-4">
          <div class="number">50<span>+</span></div>
          <div class="caption">Estates Completed</div>
        </div>
      </div>
    </div>
  </section>


  <!-- ──── PORTFOLIO ──────────────────────────────────────────────────────────────────────────────────────────────────────────────────── -->
  <section class="portfolio" id="work">
    <div class="section-header reveal">
      <div class="section-header-left">
        <span class="label">Selected Work</span>
        <h2>Our Portfolio</h2>
      </div>
      <div class="section-header-right">
        <a href="#contact">Inquire about a project →</a>
      </div>
    </div>

    <div class="portfolio-grid">
      <div class="portfolio-item reveal">
        <img class="portfolio-img" src="https://images.unsplash.com/photo-1613977257363-707ba9348227?auto=format&fit=crop&w=1600&q=80" alt="Beverly Hills Estate" loading="lazy" />
        <div class="portfolio-overlay">
          <div class="portfolio-info">
            <span class="portfolio-name">Beverly Hills Estate</span>
            <span class="portfolio-detail">Ground-Up Construction · 12,400 SF</span>
          </div>
        </div>
      </div>

      <div class="portfolio-item reveal reveal-delay-1">
        <img class="portfolio-img" src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?auto=format&fit=crop&w=900&q=80" alt="Bel Air Residence" loading="lazy" />
        <div class="portfolio-overlay">
          <div class="portfolio-info">
            <span class="portfolio-name">Bel Air Residence</span>
            <span class="portfolio-detail">Full Renovation · 9,800 SF</span>
          </div>
        </div>
      </div>

      <div class="portfolio-item reveal reveal-delay-2">
        <img class="portfolio-img" src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?auto=format&fit=crop&w=900&q=80" alt="Holmby Hills Manor" loading="lazy" />
        <div class="portfolio-overlay">
          <div class="portfolio-info">
            <span class="portfolio-name">Holmby Hills Manor</span>
            <span class="portfolio-detail">Custom Build · 15,200 SF</span>
          </div>
        </div>
      </div>

      <div class="portfolio-item reveal reveal-delay-1">
        <img class="portfolio-img" src="https://images.unsplash.com/photo-1512917774080-9991f1c4c750?auto=format&fit=crop&w=1400&q=80" alt="Brentwood Contemporary" loading="lazy" />
        <div class="portfolio-overlay">
          <div class="portfolio-info">
            <span class="portfolio-name">Brentwood Contemporary</span>
            <span class="portfolio-detail">Full Renovation · 7,600 SF</span>
          </div>
        </div>
      </div>

      <div class="portfolio-item reveal reveal-delay-2">
        <img class="portfolio-img" src="https://images.unsplash.com/photo-1580587771525-78b9dba3b914?auto=format&fit=crop&w=1600&q=80" alt="Pacific Palisades Estate" loading="lazy" />
        <div class="portfolio-overlay">
          <div class="portfolio-info">
            <span class="portfolio-name">Pacific Palisades Estate</span>
            <span class="portfolio-detail">Ground-Up Construction · 11,000 SF</span>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ──── STORY ──────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────── -->
  <section class="story" id="story">
    <div class="container">
      <div class="story-grid">
        <div class="story-image-wrap reveal">
          <img class="story-img" src="https://images.unsplash.com/photo-1560185007-cde436f6a4d0?auto=format&fit=crop&w=900&q=80" alt="A Construction Group team" loading="lazy" />
          <div class="story-badge">
            <div class="badge-num">25</div>
            <div class="badge-text">Years of<br>Excellence</div>
          </div>
        </div>
        <div class="story-content">
          <span class="label reveal">Our Story</span>
          <h2 class="reveal">A Family Built<br>on <em>Craft</em></h2>
          <div class="story-divider reveal"></div>
          <p class="reveal">
            <strong>A Construction Group Inc.</strong> was founded on a belief that luxury
            construction demands more than technical expertise — it demands a personal
            investment in every client's vision. Led by <strong>Amir Hasson</strong> and his son,
            our family-run firm has spent over two decades earning the trust of Beverly
            Hills' most discerning homeowners.
          </p>
          <p class="reveal reveal-delay-1">
            Operating at the intersection of architecture, design, and master craftsmanship,
            we don't just build homes — we collaborate deeply with world-class architects
            and interior designers to realize spaces that are as thoughtfully composed as
            they are beautifully built. Our reputation is built entirely on referrals: a
            testament to the relationships we forge and the results we deliver.
          </p>
          <p class="reveal reveal-delay-2">
            Every project we take on carries the Hasson name — and with it, our unconditional
            commitment to precision, partnership, and permanence.
          </p>
          <div class="story-values reveal reveal-delay-3">
            <div class="story-value">
              <div class="story-value-title">Precision</div>
              <div class="story-value-text">Exacting standards at every phase of construction, from site preparation to final finish.</div>
            </div>
            <div class="story-value">
              <div class="story-value-title">Partnership</div>
              <div class="story-value-text">Deep collaboration with architects, designers, and clients — from vision to completion.</div>
            </div>
            <div class="story-value">
              <div class="story-value-title">Legacy</div>
              <div class="story-value-text">Family-owned means every project carries a personal stake beyond the contract.</div>
            </div>
            <div class="story-value">
              <div class="story-value-title">Discretion</div>
              <div class="story-value-text">We protect our clients' privacy with the same care we bring to their homes.</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ──── SERVICES ──────────────────────────────────────────────────────────────────────────────────────────────────────────────────── -->
  <section class="services" id="services">
    <div class="container">
      <div class="services-intro reveal">
        <span class="label">What We Do</span>
        <h2>Built for Every<br>Vision</h2>
        <p>Whether starting from the ground up or transforming an existing estate, our team brings the same level of craft and care to every scope of work.</p>
      </div>
      <div class="services-grid">
        <div class="service-item reveal">
          <div class="service-num">01</div>
          <div class="service-title">Ground-Up<br>Construction</div>
          <div class="service-divider"></div>
          <div class="service-desc">
            From foundation to final detail — we manage every phase of new custom
            home construction. Working directly with your architect and design team
            to bring a complete vision to life on any site in the Los Angeles area.
          </div>
        </div>
        <div class="service-item reveal reveal-delay-1">
          <div class="service-num">02</div>
          <div class="service-title">Full-Scope<br>Renovation</div>
          <div class="service-divider"></div>
          <div class="service-desc">
            Total transformation of existing luxury residences. We approach every
            renovation with the same level of structural rigor and finish quality
            as new construction — because the result demands nothing less.
          </div>
        </div>
        <div class="service-item reveal reveal-delay-2">
          <div class="service-num">03</div>
          <div class="service-title">Design-Build<br>Partnership</div>
          <div class="service-divider"></div>
          <div class="service-desc">
            For clients who want a single trusted team to guide the entire process,
            we co-lead from concept through completion alongside our network of
            premier architects and interior designers.
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ──── PARTNERS ──────────────────────────────────────────────────────────────────────────────────────────────────────────────────── -->
  <section class="partners" id="partners">
    <div class="container">
      <div class="partners-header reveal">
        <span class="label">Design Partnerships</span>
        <h2>Built Alongside<br>the Best</h2>
        <p>We collaborate exclusively with the most respected names in luxury residential design — bringing together vision and craft at the highest level.</p>
      </div>
    </div>
    <div style="max-width: 1280px; margin: 0 auto; padding: 0 48px;">
      <div class="partners-grid">
        <div class="partner-card reveal">
          <img class="partner-bg" src="https://images.unsplash.com/photo-1586023492125-27b2c045efd1?auto=format&fit=crop&w=1200&q=80" alt="The Clements Design interior" loading="lazy" />
          <div class="partner-overlay"></div>
          <div class="partner-content">
            <div class="partner-category">Interior Design Partner</div>
            <div class="partner-name">The Clements<br>Design</div>
            <div class="partner-desc">
              One of Los Angeles' most celebrated interior design studios, known
              for creating warm, layered residential environments that balance
              sophistication with soul.
            </div>
            <a href="https://clementsdesign.com" target="_blank" rel="noopener noreferrer" class="partner-link">
              Visit Studio →
            </a>
          </div>
        </div>
        <div class="partner-card reveal reveal-delay-1">
          <img class="partner-bg" src="https://images.unsplash.com/photo-1618219878829-ab2e72b0f597?auto=format&fit=crop&w=1200&q=80" alt="Clint Nicholas interior" loading="lazy" />
          <div class="partner-overlay"></div>
          <div class="partner-content">
            <div class="partner-category">Interior Design Partner</div>
            <div class="partner-name">Clint Nicholas<br>Design</div>
            <div class="partner-desc">
              A visionary approach to luxury interiors with a singular editorial
              aesthetic. Clint Nicholas brings the sensibility of a collector and
              the precision of an architect to every collaboration.
            </div>
            <a href="https://clintnicholasdesign.com" target="_blank" rel="noopener noreferrer" class="partner-link">
              Visit Studio →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ──── CONTACT ──────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────── -->
  <section class="contact" id="contact">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-left">
          <span class="label reveal">Get in Touch</span>
          <h2 class="reveal">Begin Your<br><em>Project</em></h2>
          <p class="reveal">
            We work with a select number of clients each year. If you are considering
            building or transforming a luxury residence in the Los Angeles area, we
            welcome a private conversation.
          </p>
          <div class="contact-details">
            <div class="reveal">
              <div class="contact-item-label">Location</div>
              <div class="contact-item-value">Beverly Hills, CA 90210</div>
            </div>
            <div class="reveal reveal-delay-1">
              <div class="contact-item-label">Email</div>
              <div class="contact-item-value">
                <a href="mailto:info@aconstructiongroup.com">info@aconstructiongroup.com</a>
              </div>
            </div>
            <div class="reveal reveal-delay-2">
              <div class="contact-item-label">Phone</div>
              <div class="contact-item-value">
                <a href="tel:+13105550100">(310) 555-0100</a>
              </div>
            </div>
          </div>
        </div>

        <div class="contact-form reveal reveal-delay-1">
          <form name="contact" netlify>
            <div class="form-row">
              <div class="field">
                <label for="fname">First Name</label>
                <input type="text" id="fname" name="fname" placeholder="First name" required />
              </div>
              <div class="field">
                <label for="lname">Last Name</label>
                <input type="text" id="lname" name="lname" placeholder="Last name" required />
              </div>
            </div>
            <div class="field">
              <label for="email">Email Address</label>
              <input type="email" id="email" name="email" placeholder="your@email.com" required />
            </div>
            <div class="field">
              <label for="phone">Phone Number</label>
              <input type="tel" id="phone" name="phone" placeholder="(310) 000-0000" />
            </div>
            <div class="field">
              <label for="project">Project Type</label>
              <select id="project" name="project">
                <option value="" disabled selected>Select project type</option>
                <option value="ground-up">Ground-Up Construction</option>
                <option value="renovation">Full Renovation</option>
                <option value="design-build">Design-Build Partnership</option>
                <option value="other">Other Inquiry</option>
              </select>
            </div>
            <div class="field">
              <label for="message">Tell Us About Your Vision</label>
              <textarea id="message" name="message" placeholder="Describe your project, location, and timeline..."></textarea>
            </div>
            <button type="submit" class="form-submit">
              Send Inquiry
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M2 8h12M9 3l5 5-5 5"/>
              </svg>
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>


  <!-- ──── FOOTER ──────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────── -->
  <footer class="footer">
    <div class="container">
      <div class="footer-top">
        <div>
          <div class="footer-logo">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 220 72" fill="none">
              <polygon points="0,64 22,8 30,8 10,64" fill="#EDE8E0"/>
              <polygon points="44,64 22,8 30,8 52,64" fill="#EDE8E0"/>
              <rect x="12" y="36" width="30" height="3.5" fill="#EDE8E0"/>
              <polygon points="22,8 26,0 30,8" fill="#C4A87E"/>
              <text x="70" y="30" font-family="'Cormorant Garamond', Georgia, serif" font-size="17" font-weight="300" letter-spacing="5" fill="#EDE8E0">CONSTRUCTION</text>
              <text x="70" y="52" font-family="'Cormorant Garamond', Georgia, serif" font-size="17" font-weight="300" letter-spacing="5" fill="#EDE8E0">GROUP INC.</text>
              <rect x="70" y="35" width="148" height="0.75" fill="#C4A87E" opacity="0.6"/>
            </svg>
          </div>
          <p class="footer-tagline">
            Family-owned luxury residential construction in Beverly Hills and greater Los Angeles.
          </p>
        </div>
        <div>
          <div class="footer-col-title">Navigation</div>
          <nav class="footer-links" aria-label="Footer Navigation">
            <a href="#work">Our Work</a>
            <a href="#story">Our Story</a>
            <a href="#services">Services</a>
            <a href="#partners">Partners</a>
            <a href="#contact">Contact</a>
          </nav>
        </div>
        <div>
          <div class="footer-col-title">Contact</div>
          <address class="footer-address">
            Beverly Hills, CA 90210<br/>
            <a href="mailto:info@aconstructiongroup.com" style="color:var(--text-3); transition:color 0.2s;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-3)'">info@aconstructiongroup.com</a><br/>
            <a href="tel:+13105550100" style="color:var(--text-3); transition:color 0.2s;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-3)'">(310) 555-0100</a>
          </address>
        </div>
      </div>
      <div class="footer-bottom">
        <div class="footer-copy">
          © 2026 A Construction Group Inc. All rights reserved.
        </div>
        <div class="footer-socials">
          <a href="#" aria-label="Instagram">Instagram</a>
          <a href="#" aria-label="Houzz">Houzz</a>
          <a href="#" aria-label="LinkedIn">LinkedIn</a>
        </div>
      </div>
    </div>
  </footer>


  <!-- ──── JAVASCRIPT ──────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────── -->
  <script>
    // ── Nav scroll behavior ──────────────────────────────────────────────────────────────────────────────────────────
    const nav = document.getElementById('nav');
    window.addEventListener('scroll', () => {
      nav.classList.toggle('scrolled', window.scrollY > 40);
    }, { passive: true });

    // ── Hero entrance animation ────────────────────────────────────────────────────────────────────────────────────────
    const heroBg = document.getElementById('heroBg');
    const heroEyebrow = document.getElementById('heroEyebrow');
    const heroH1 = document.getElementById('heroH1');
    const heroDesc = document.getElementById('heroDesc');
    const heroActions = document.getElementById('heroActions');

    window.addEventListener('load', () => {
      heroBg.classList.add('loaded');
      setTimeout(() => heroEyebrow.classList.add('visible'), 200);
      setTimeout(() => heroH1.classList.add('visible'), 200);
      setTimeout(() => heroDesc.classList.add('visible'), 200);
      setTimeout(() => heroActions.classList.add('visible'), 200);
    });

    // ── Scroll reveal ──────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────
    const reveals = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          observer.unobserve(e.target);
        }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
    reveals.forEach(el => observer.observe(el));

    // ── Mobile menu ─────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────
    const hamburger = document.getElementById('hamburger');
    const mobileMenu = document.getElementById('mobileMenu');
    let menuOpen = false;

    hamburger.addEventListener('click', () => {
      menuOpen = !menuOpen;
      hamburger.setAttribute('aria-expanded', menuOpen);
      if (menuOpen) {
        mobileMenu.style.display = 'flex';
        requestAnimationFrame(() => mobileMenu.classList.add('open'));
        document.body.style.overflow = 'hidden';
      } else {
        mobileMenu.classList.remove('open');
        setTimeout(() => { mobileMenu.style.display = 'none'; }, 300);
        document.body.style.overflow = '';
      }
    });

    document.querySelectorAll('.mobile-link').forEach(link => {
      link.addEventListener('click', () => {
        menuOpen = false;
        hamburger.setAttribute('aria-expanded', false);
        mobileMenu.classList.remove('open');
        setTimeout(() => { mobileMenu.style.display = 'none'; }, 300);
        document.body.style.overflow = '';
      });
    });

    // ── Smooth scroll for anchor links ────────────────────────────────────────────────────────────────────────────────────────────────────────
    document.querySelectorAll('a[href^="#"]').forEach(a => {
      a.addEventListener('click', e => {
        const target = document.querySelector(a.getAttribute('href'));
        if (target) {
          e.preventDefault();
          const navH = nav.offsetHeight;
          const top = target.getBoundingClientRect().top + window.scrollY - navH;
          window.scrollTo({ top, behavior: 'smooth' });
        }
      });
    });

    // ── Parallax hero bg on scroll ──────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────
    window.addEventListener('scroll', () => {
      const y = window.scrollY;
      if (y < window.innerHeight) {
        heroBg.style.transform = `scale(1) translateY(${y * 0.25}px)`;
      }
    }, { passive: true });
  </script>

</body>
</html>
